---
import Base from "../layouts/Base.astro";
import HeroTessellation from "../components/HeroTessellation.astro";
import CatalogueBrowser from "../components/CatalogueBrowser.tsx";
import { flat, valueStreams, version } from "../data/load.ts";
---

<Base
  title=""
  description="Browse, filter, and export an open Business Capability Reference Catalog."
  navTransparent={true}
>
  <HeroTessellation
    title="Business Capability Reference Catalog"
    description={`${version.node_count} capabilities · catalog ${version.catalogue_version} · schema v${version.schema_version}`}
  />

  <main class="main">
    <CatalogueBrowser data={flat} valueStreams={valueStreams} client:load />
  </main>
</Base>
