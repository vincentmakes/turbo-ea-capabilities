---
import Base from "../layouts/Base.astro";
import CatalogueBrowser from "../components/CatalogueBrowser.tsx";
import { flat, valueStreams } from "../data/load.ts";
---

<Base title="Search">
  <main class="main">
    <div class="section-header">
      <h2>Search</h2>
    </div>
    <p class="search-results-info" style="margin-bottom: 24px;">
      Full-text search across id, name, description, and aliases.
    </p>
    <CatalogueBrowser data={flat} valueStreams={valueStreams} client:load />
  </main>
</Base>
